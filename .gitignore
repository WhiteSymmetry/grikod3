# Prerequisites
*.d

# Object files
*.o
*.ko
*.obj
*.elf

# Linker output
*.ilk
*.map
*.exp

# Precompiled Headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Kernel Module Compile Results
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

# debug information files
*.dwo

# --------------------------------------------------
# Python / Cython derleme ara ürünleri (isteğe bağlı)
# --------------------------------------------------
*.c
*.pyc
__pycache__/

# --------------------------------------------------
# **Özel istisnalar:** grikod3/ klasöründeki derlenmiş uzantıları izle
# --------------------------------------------------
!grikod3/*.so
!grikod3/*.pyd
!grikod3/*.dylib
!grikod3/*.c
